{
  "realm": "smart-sentinel-eye",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "verifyEmail": false,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1)",
  "roles": {
    "realm": [
      { "name": "user", "description": "Standard user role" },
      { "name": "admin", "description": "Administrator role" }
    ]
  },
  "defaultRoles": ["user"],
  "groups": [
    {
      "name": "fabs",
      "subGroups": [
        { "name": "munich", "path": "/fabs/munich" }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "sse.management",
      "description": "Legacy bundle (spec 001-007). Grandfathered until per-endpoint sse.*.write migration in spec 008 PR F.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "sub-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "preferred-username-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    },
    { "name": "sse.cameras.read", "description": "Read camera catalogue.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.cameras.write", "description": "Mutate camera catalogue.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.streams.read", "description": "Read stream metadata.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.streams.write", "description": "Mutate stream resources.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.layouts.read", "description": "Read kiosk layouts.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.layouts.write", "description": "Author kiosk layouts.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.overlays.read", "description": "Read overlays.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.overlays.write", "description": "Author overlays.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.variables.read", "description": "Read system variables.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.variables.write", "description": "Mutate system variables.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.rules.read", "description": "Read automation rules.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.rules.write", "description": "Author automation rules.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.events.read", "description": "Read events ledger.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.events.write", "description": "Manual event ingest + webhook ingest.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.events.publish", "description": "MQTT publish on per-device topics.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.webhooks.write", "description": "Manage webhook integrations.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.identity.devices.write", "description": "Register and disable device clients.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "sse.identity.kiosks.write", "description": "Enroll and disable kiosk clients.", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    {
      "name": "sse-groups",
      "description": "Emits /fabs/<id> group memberships into the 'groups' JWT claim.",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "groups-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "smart-sentinel-eye-web",
      "name": "Smart Sentinel Eye Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://localhost:*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles",
        "sse.management"
      ]
    },
    {
      "clientId": "smart-sentinel-eye-kiosk",
      "name": "Smart Sentinel Eye Kiosk App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5174/oidc/callback",
        "http://localhost:5174/*",
        "http://localhost:*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles",
        "sse.management"
      ]
    },
    {
      "clientId": "management-web",
      "name": "Smart Sentinel Eye — Management Web (spec 008 v2)",
      "description": "Replaces smart-sentinel-eye-web in spec 009.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic", "profile", "email", "roles", "sse-groups",
        "sse.cameras.read", "sse.cameras.write",
        "sse.streams.read", "sse.streams.write",
        "sse.layouts.read", "sse.layouts.write",
        "sse.overlays.read", "sse.overlays.write",
        "sse.variables.read", "sse.variables.write",
        "sse.rules.read", "sse.rules.write",
        "sse.events.read", "sse.events.write",
        "sse.webhooks.write",
        "sse.identity.devices.write",
        "sse.identity.kiosks.write"
      ]
    },
    {
      "clientId": "kiosk-web",
      "name": "Smart Sentinel Eye — Kiosk Web (spec 008 v2)",
      "description": "Replaces smart-sentinel-eye-kiosk in spec 009.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5174/*",
        "http://localhost:*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic", "profile", "email", "roles", "sse-groups",
        "sse.cameras.read",
        "sse.streams.read",
        "sse.layouts.read",
        "sse.overlays.read",
        "sse.variables.read",
        "sse.events.write"
      ]
    },
    {
      "clientId": "identity-admin",
      "name": "Smart Sentinel Eye — Identity Admin (service account)",
      "description": "Used by the Identity API to create/rotate Keycloak clients via the Admin REST API.",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "dev-only-identity-admin-secret",
      "protocol": "openid-connect",
      "defaultClientScopes": ["basic", "profile", "email", "roles"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@smart-sentinel-eye.test",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    },
    {
      "username": "operator",
      "enabled": true,
      "emailVerified": true,
      "email": "operator@smart-sentinel-eye.test",
      "firstName": "Operator",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Operator1234",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "admin@munich.test",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@munich.test",
      "firstName": "Munich",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "Admin1234", "temporary": false }
      ],
      "realmRoles": ["user", "admin"],
      "groups": ["/fabs/munich"]
    },
    {
      "username": "op-3@munich.test",
      "enabled": true,
      "emailVerified": true,
      "email": "op-3@munich.test",
      "firstName": "Munich",
      "lastName": "Operator",
      "credentials": [
        { "type": "password", "value": "Operator1234", "temporary": false }
      ],
      "realmRoles": ["user"],
      "groups": ["/fabs/munich"]
    },
    {
      "username": "service-account-identity-admin",
      "enabled": true,
      "serviceAccountClientId": "identity-admin",
      "clientRoles": {
        "realm-management": [
          "manage-clients",
          "manage-users",
          "view-clients",
          "view-users",
          "query-clients",
          "query-users",
          "query-groups"
        ]
      }
    }
  ]
}
